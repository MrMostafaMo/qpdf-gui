{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "QPDF GUI",
  "version": "1.0.0",
  "identifier": "com.qpdf.gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "QPDF GUI",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "category": "Utility",
    "shortDescription": "Cross-platform desktop PDF toolbox",
    "longDescription": "A cross-platform desktop application for PDF manipulation powered by qpdf. Supports extract, merge, split, rotate, delete, encrypt, decrypt, optimize, linearize, and batch operations."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxQjc2MTczQjI4NDNBNzgKUldSNE9vU3ljMkczZ2Z4T29XVnovTGtHOHlzOFQ1ZEhzb0UxdEloMkV1TlBJZDlSaldvOEtsVDkK",
      "endpoints": [
        "https://github.com/MrMostafaMo/qpdf-gui/releases/latest/download/latest.json"
      ]
    }
  }
}
