{
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-stat",
    "fs:allow-exists",
    "shell:default",
    "shell:allow-open",
    "store:default",
    "updater:default",
    "notification:default"
  ]
}
